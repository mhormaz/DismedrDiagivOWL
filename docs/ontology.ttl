###  http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/DeviceIVD
<http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/DeviceIVD> rdf:type owl:Class ;
                                                                             owl:equivalentClass [ owl:intersectionOf ( <http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Device>
                                                                                                                        [ rdf:type owl:Restriction ;
                                                                                                                          owl:onProperty <http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/risk_class> ;
                                                                                                                          owl:someValuesFrom <http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/IVDRiskClass>
                                                                                                                        ]
                                                                                                                      ) ;
                                                                                                   rdf:type owl:Class
                                                                                                 ] ;
                                                                             owl:disjointWith <http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/DeviceMD> .


###  http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/DeviceMD
<http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/DeviceMD> rdf:type owl:Class ;
