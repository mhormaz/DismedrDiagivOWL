                                                                                                                       [ rdf:type owl:Restriction ;
                                                                                                                         owl:onProperty <http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/risk_class> ;
                                                                                                                         owl:someValuesFrom <http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/MDRiskClass>
                                                                                                                       ]
                                                                                                                     ) ;
                                                                                                  rdf:type owl:Class
                                                                                                ] .


###  http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/DeviceType
<http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/DeviceType> rdf:type owl:Class ;
