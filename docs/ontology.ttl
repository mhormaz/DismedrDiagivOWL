                                                                              rdfs:label "DeviceType" .


###  http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/FSCA
<http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/FSCA> rdf:type owl:Class ;
                                                                        owl:equivalentClass [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                                                     owl:onProperty <http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/FSCA_countries_affected> ;
                                                                                                                     owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                                     owl:onClass <http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Country>
                                                                                                                   ]
                                                                                                                   [ rdf:type owl:Restriction ;
                                                                                                                     owl:onProperty <http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/closure_date> ;
                                                                                                                     owl:someValuesFrom xsd:dateTime
                                                                                                                   ]
                                                                                                                 ) ;
                                                                                              rdf:type owl:Class
                                                                                            ] ;
                                                                        rdfs:comment "The security corrective action in the field against incidents" ;
                                                                        rdfs:label "FSCA" .


