        <rdfs:comment>The action type of a FSCA</rdfs:comment>
        <rdfs:label>action_type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/affected_device_type -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/affected_device_type">
