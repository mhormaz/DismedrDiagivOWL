        <rdfs:range rdf:resource="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/RiskType"/>
        <rdfs:comment>The risk type of some riske</rdfs:comment>
        <rdfs:label>risk_type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/severity -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/severity">
