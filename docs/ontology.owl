        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The incident&apos;s eudamed code</rdfs:comment>
        <rdfs:label>eudamed_incident_ref</rdfs:label>
    </owl:DatatypeProperty>
    


