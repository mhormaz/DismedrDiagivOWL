        <rdfs:label>risk_class</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/risk_type -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/risk_type">
