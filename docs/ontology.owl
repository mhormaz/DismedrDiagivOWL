        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The name of the device</rdfs:comment>
        <rdfs:label>device_name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/devices_affected -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/devices_affected">
