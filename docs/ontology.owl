        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The manufacturer&apos;s identifier</rdfs:comment>
        <rdfs:label>manufacturer_id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/name -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/name">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Manufacturer"/>
