        <rdfs:range rdf:resource="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Country"/>
        <rdfs:comment>The countries affected by the FSCA</rdfs:comment>
        <rdfs:label>countries_affected</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/FSCA_incident_id -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/FSCA_incident_id">
