        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>The action&apos;s closure date</rdfs:comment>
        <rdfs:label>closure_date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/contact_email -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/contact_email">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The manufacturer&apos;s contact email</rdfs:comment>
        <rdfs:label>contact_email</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/corrective_action_taken -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/corrective_action_taken">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>If an incident has a corrective action taken or not</rdfs:comment>
        <rdfs:label>corrective_action_taken</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/detection_date -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/detection_date">
