        <rdfs:range rdf:resource="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Gender"/>
        <rdfs:comment>The gender of the patient affected</rdfs:comment>
        <rdfs:label>patient_sex</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/probability -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/probability">
