        <rdfs:range rdf:resource="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Incident"/>
        <rdfs:comment>The incident associated with a FSCA</rdfs:comment>
        <rdfs:label>incident_id</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/action_type -->


