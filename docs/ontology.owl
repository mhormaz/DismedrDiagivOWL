        <rdfs:label>device_type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/incident_device_id -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/incident_device_id">
