        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#short"/>
        <rdfs:comment>The age of the patient</rdfs:comment>
        <rdfs:label>patient_age</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/report_date -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/report_date">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>The report&apos;s date</rdfs:comment>
        <rdfs:label>report_date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/reusable -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/reusable">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>If this device is reusable or not</rdfs:comment>
        <rdfs:label>is_reusable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/risk_description -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/risk_description">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The risk description</rdfs:comment>
        <rdfs:label>description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/risk_id -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/risk_id">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The risk&apos;s identifier</rdfs:comment>
        <rdfs:label>risk_id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/risk_name -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/risk_name">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The risk&apos;s name</rdfs:comment>
        <rdfs:label>risk_name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/scope -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/scope">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The action&apos;s scope</rdfs:comment>
        <rdfs:label>scope</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/status_name -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/status_name">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Status"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The status name</rdfs:comment>
        <rdfs:label>status_name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/udi_id -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/udi_id">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique identifier of the product</rdfs:comment>
        <rdfs:label>udi_id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/ActionType -->


    <owl:Class rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/ActionType">
        <rdfs:comment>Type of action aginst an incident</rdfs:comment>
        <rdfs:label>ActionType</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/CompetentAuthority -->


    <owl:Class rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/CompetentAuthority">
        <rdfs:comment>Compentent authority for a manufacturer</rdfs:comment>
        <rdfs:label>CompetentAuthority</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Country -->


    <owl:Class rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Country">
        <rdfs:comment>The countries of the world. Used on incidentes and manufacturers</rdfs:comment>
        <rdfs:label>Country</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Device -->


    <owl:Class rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Device">
        <rdfs:comment>Names and characteristics for &quot;High risk medical devices&quot; and &quot;in vitro diagnosis&quot;, made by some manufacturer with the corresponding regulation (MDR or IVDR).</rdfs:comment>
        <rdfs:label>Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/DeviceIVD -->


    <owl:Class rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/DeviceIVD">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Device"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/risk_class"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/IVDRiskClass"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/DeviceMD"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/DeviceMD -->


    <owl:Class rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/DeviceMD">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Device"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/risk_class"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/MDRiskClass"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/DeviceType -->


    <owl:Class rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/DeviceType">
        <rdfs:comment>Tipes of medical devices and in vitro diagnosis</rdfs:comment>
        <rdfs:label>DeviceType</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/FSCA -->


    <owl:Class rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/FSCA">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/FSCA_countries_affected"/>
                        <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                        <owl:onClass rdf:resource="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Country"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/closure_date"/>
                        <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment>The security corrective action in the field against incidents</rdfs:comment>
        <rdfs:label>FSCA</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Gender -->


    <owl:Class rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Gender">
        <rdfs:comment>Gender of the patient afected by an incident</rdfs:comment>
        <rdfs:label>Gender</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/IVDRiskClass -->


    <owl:Class rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/IVDRiskClass">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/RiskClass"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/MDRiskClass"/>
        <rdfs:comment>&quot;In vitro diagonisis&quot; risk classes</rdfs:comment>
        <rdfs:label>IVDRiskClass</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Incident -->


    <owl:Class rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Incident">
        <rdfs:comment>Incident data, the device and the afected patient</rdfs:comment>
        <rdfs:label>Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/IncidentType -->


    <owl:Class rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/IncidentType">
        <rdfs:comment>Types of device incidents</rdfs:comment>
        <rdfs:label>IncidentType</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/MDRiskClass -->


    <owl:Class rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/MDRiskClass">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/RiskClass"/>
        <rdfs:comment>&quot;Medical devices&quot; risk classes</rdfs:comment>
        <rdfs:label>MDRiskClass</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Manufacturer -->


    <owl:Class rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Manufacturer">
        <rdfs:comment>The manufacturers of the devices and the company information.</rdfs:comment>
        <rdfs:label>Manufacturer</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Probability -->


    <owl:Class rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Probability">
        <rdfs:comment>Probability category of a risk. Values are &quot;Moderate&quot;, &quot;Serious&quot; and &quot;Critical&quot;.</rdfs:comment>
        <rdfs:label>Probability</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/RegulatoryFramework -->


    <owl:Class rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/RegulatoryFramework">
        <rdfs:comment>Regulatory european frameworks of devices. The frameworks are &quot;MDR&quot; and &quot;IVDR&quot;</rdfs:comment>
        <rdfs:label>RegulatoryFramework</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Risk -->


    <owl:Class rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Risk">
        <rdfs:comment>Known risk of a certain device type</rdfs:comment>
        <rdfs:label>Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/RiskCategory -->


    <owl:Class rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/RiskCategory">
        <rdfs:comment>Categories of risks</rdfs:comment>
        <rdfs:label>RiskCategory</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/RiskClass -->


    <owl:Class rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/RiskClass">
        <rdfs:comment>Classes of risks</rdfs:comment>
        <rdfs:label>RiskClass</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/RiskType -->


    <owl:Class rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/RiskType">
        <rdfs:comment>Types of risks</rdfs:comment>
        <rdfs:label>RiskType</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Severity -->


    <owl:Class rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Severity">
