        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment>The name of the authority</rdfs:comment>
        <rdfs:label>authority_name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/authorization_number -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/authorization_number">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The number generated by the authorization. The pattern is: country/year/6 digit number</rdfs:comment>
        <rdfs:label>authorization_number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/closure_date -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/closure_date">
