        <rdfs:label>manufacturer_id</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/device_type -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/device_type">
