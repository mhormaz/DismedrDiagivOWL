    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/reporting_entity -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/reporting_entity">
