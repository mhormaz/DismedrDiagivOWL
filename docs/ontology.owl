        <rdfs:range rdf:resource="http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/DeviceType"/>
        <rdfs:comment>The affected device type of some riske</rdfs:comment>
        <rdfs:label>affected_device_type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/marco/ontologies/2026/3/DismedrDiagiv/competent_authority -->


